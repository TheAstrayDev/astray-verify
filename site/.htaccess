DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^(includes|config|storage|sql)/ - [F,L]
  RewriteRule ^project/([a-z0-9\-]+)/?$ project.php?slug=$1 [L,QSA]
  RewriteRule ^cli/?$ /verify [R=301,L]
  RewriteRule ^verify/?$ verify.php [L,QSA]
  RewriteRule ^install/?$ install.sh [L]
  RewriteRule ^sitemap\.xml$ sitemap.php [L]
  RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
  RewriteRule ^index\.php$ / [R=301,L]
  RewriteCond %{THE_REQUEST} \s/+project\.php\?slug=([a-z0-9\-]+) [NC]
  RewriteRule ^project\.php$ /project/%1? [R=301,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|webp|woff2?|ico|txt|webmanifest)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
  <FilesMatch "\.(php|html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType text/plain .txt
  AddType application/xml .xml
</IfModule>

<FilesMatch "^\.">
  Require all denied
</FilesMatch>
